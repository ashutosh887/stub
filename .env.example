# Aurora DSQL — required.
DSQL_ENDPOINT=your-cluster-id.dsql.us-east-1.on.aws
DSQL_REGION=us-east-1
DSQL_DATABASE=postgres
DSQL_USER=admin

# Connection pool. IMPORTANT on serverless (Vercel): set DSQL_POOL_MAX=1 — each
# function instance holds its own pool, so a high max multiplies connections.
# DSQL_POOL_MAX=5
# DSQL_PORT=5432
# DSQL_IDLE_TIMEOUT_MS=30000
# DSQL_CONNECTION_TIMEOUT_MS=10000
# DSQL_MAX_LIFETIME_SECONDS=600

# Cross-region overspend proof (`npm run test:live`). Without DSQL_ENDPOINT_PEER
# the live test auto-skips.
# DSQL_ENDPOINT_PEER=your-peer-cluster-id.dsql.us-east-2.on.aws
# DSQL_REGION_PEER=us-east-2

# Natural-language query.
# Primary engine is OpenAI (set OPENAI_API_KEY). If it errors or is unset, the box falls back to a
# built-in deterministic parser automatically (free, offline). OPENAI_MODEL is optional.
OPENAI_API_KEY=your-openai-api-key
# OPENAI_MODEL=gpt-4o-mini

# Admin auth. When ADMIN_TOKEN is set, the dashboard + mutating/data API routes require it
# (login at /api/auth, or Authorization: Bearer). When unset, routes are open (local dev / demo).
# ADMIN_TOKEN=choose-a-long-random-secret

# Operational tuning (all optional — sensible defaults shown).
# LOG_LEVEL=info                  # debug | info | warn | error
# MAX_SPEND_USD=1000000           # upper bound on a single spend
# MAX_RECEIPT_BYTES=64000         # cap on the x402 receipt JSON
# MAX_QUESTION_LENGTH=500         # NL query input cap
# OCC_MAX_RETRIES=25              # serialization-failure retries before 503
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_MAX=120              # per route per identity per window
# RATE_LIMIT_QUERY_MAX=20         # tighter limit for /api/query (OpenAI cost)

# Demo agent (`npm run demo:agent`). Points the SDK at a running Stub instance.
# STUB_BASE_URL=http://localhost:3000
# DEMO_SPENDS=12
# DEMO_PRICE_USD=0.40
