DSQL_ENDPOINT=your-cluster-id.dsql.us-east-1.on.aws
DSQL_REGION=us-east-1
DSQL_DATABASE=postgres
DSQL_USER=admin

# Natural-language query.
# Primary engine is OpenAI (set OPENAI_API_KEY). If it errors or is unset, the box falls back to a
# built-in deterministic parser automatically (free, offline). OPENAI_MODEL is optional.
OPENAI_API_KEY=your-openai-api-key
# OPENAI_MODEL=gpt-4o-mini
